# SQLAlchemy connection string — Supabase's pooled/pgbouncer transaction-mode
# connection string (port 6543). Used for all normal querying/schema reads.
# Local Postgres also works here for local-only development.
DATABASE_URL=postgresql://postgres.your_project_ref:your_password@aws-0-your-region.pooler.supabase.com:6543/postgres

# Used only for CREATE TABLE / INSERT when uploading a new dataset via the
# /upload endpoint. Must be Supabase's SESSION pooler connection string (same
# pooler hostname as DATABASE_URL, but port 5432, not the true "Direct
# connection" shown in the Supabase dashboard — that one is IPv6-only and
# unreachable from Vercel/most serverless platforms). Falls back to
# DATABASE_URL if unset.
DATABASE_URL_DIRECT=postgresql://postgres.your_project_ref:your_password@aws-0-your-region.pooler.supabase.com:5432/postgres

# API key from console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Groq model used for SQL/chart generation
MODEL_NAME=llama-3.3-70b-versatile

# Legacy — only used by the old Streamlit UI (app/ui/streamlit_app.py),
# which the app/frontend served by main.py has replaced. Not needed for the
# current architecture; harmless to leave unset.
API_BASE_URL=http://localhost:8000
