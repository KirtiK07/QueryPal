# SQLAlchemy connection string — point this at your Supabase project's
# pooled/pgbouncer connection string (port 6543), not the direct one (5432).
# Local Postgres also works here for local-only development.
DATABASE_URL=postgresql://postgres.your_project_ref:your_password@aws-0-your-region.pooler.supabase.com:6543/postgres

# Direct (non-pooled) Supabase connection string (port 5432), used only for
# CREATE TABLE / INSERT when uploading a new dataset from the Streamlit UI.
# Needed wherever the Streamlit app runs, since it writes to Supabase directly.
# Falls back to DATABASE_URL if unset.
DATABASE_URL_DIRECT=postgresql://postgres:your_password@db.your_project_ref.supabase.co:5432/postgres

# API key from console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Groq model used for SQL/chart generation
MODEL_NAME=llama-3.3-70b-versatile

# Base URL of the deployed FastAPI backend, used only by the Streamlit UI.
# Leave unset for local development (defaults to http://localhost:8000).
API_BASE_URL=http://localhost:8000
